# ─────────────────────────────────────────────────────────────────
# Levisa Capital — frontend environment variables (Vite)
#
# HOW TO USE
#   Local dev:  copy this file to .env.local and fill in real values,
#               then restart `npm run dev` (Vite reads env at startup).
#   Vercel:     add these two as Environment Variables in the project,
#               enabled for Production + Preview + Development, then
#               redeploy (Vite bakes them into the build).
#
# Only variables prefixed with VITE_ are exposed to the browser.
# Get both values from: Supabase Dashboard → Project Settings → API
# ─────────────────────────────────────────────────────────────────

# Project URL — the bare URL, no trailing path (NOT .../rest/v1)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# anon / public key (role = anon). NEVER put the service_role key here —
# it bypasses all RLS and must stay server-side only (edge functions / n8n).
VITE_SUPABASE_ANON_KEY=your-anon-public-key
