# Edge Functions pick these up automatically from the Supabase platform.
# You do NOT need to fill these in — Supabase injects them at runtime.
# They are listed here only for local development with `supabase functions serve`.
#
# Copy values from: Dashboard → Project Settings → API

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
